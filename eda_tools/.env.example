# EDA service configuration
REDIS_URL=redis://localhost:6379

API_HOST=0.0.0.0
API_PORT=8002
API_PREFIX=/api/eda

APP_NAME=CircuitGPT EDA Service
DEBUG_MODE=true

SKIDL_PATH=./skidl
PYSPICE_PATH=./pyspice
KICAD_PATH=./kicad
BOM_PATH=./bom

STORAGE_PATH=./storage

MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=600

LOG_LEVEL=info
LOG_FILE=./logs/eda_service.log

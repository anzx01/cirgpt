# AI service configuration
REDIS_URL=redis://localhost:6379

MODEL_PATH=./models/circuit_bert
MODEL_NAME=circuit_bert-base
MODEL_DEVICE=cpu

# Optional large-model parser. Put your real key in ai_service/.env or the
# repository-level .env file; do not commit secrets.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30

API_HOST=0.0.0.0
API_PORT=8001
API_PREFIX=/api/ai

APP_NAME=CircuitGPT AI Service
DEBUG_MODE=true

MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=300

LOG_LEVEL=info
LOG_FILE=./logs/ai_service.log
